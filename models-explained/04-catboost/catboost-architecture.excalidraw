    {
      "type": "text",
      "id": "leak_code_text",
      "x": 75,
      "y": 145,
      "width": 350,
      "height": 120,
      "text": "Standard target encoding:\n  cat=\"NYC\" \u2192 mean(y where city=NYC) = 0.73\n\n\u26a0 Uses ALL samples including self!\n  \u2192 label leaks into feature\n  \u2192 rare categories memorized\n  \u2192 overfitting",
      "originalText": "Standard target encoding:\n  cat=\"NYC\" \u2192 mean(y where city=NYC) = 0.73\n\n\u26a0 Uses ALL samples including self!\n  \u2192 label leaks into feature\n  \u2192 rare categories memorized\n  \u2192 overfitting",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#22c55e",
