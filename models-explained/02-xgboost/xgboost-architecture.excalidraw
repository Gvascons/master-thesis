    {
      "type": "text",
      "id": "tree_note",
      "x": 60,
      "y": 560,
      "width": 400,
      "height": 40,
      "text": "Leaf weights = optimal correction for the current residuals\nw*\u2c7c = -\u03a3g\u1d62 / (\u03a3h\u1d62 + \u03bb) using 2nd-order gradients",
      "originalText": "Leaf weights = optimal correction for the current residuals\nw*\u2c7c = -\u03a3g\u1d62 / (\u03a3h\u1d62 + \u03bb) using 2nd-order gradients",
