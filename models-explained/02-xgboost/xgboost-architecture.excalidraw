    {
      "type": "rectangle",
      "id": "innov_code",
      "x": 530,
      "y": 310,
      "width": 400,
      "height": 330,
      "strokeColor": "#1e293b",
      "backgroundColor": "#1e293b",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 20310,
      "version": 1,
      "versionNonce": 20311,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": [
        {
          "id": "innov_code_text",
