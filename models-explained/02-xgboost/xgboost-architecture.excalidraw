      }
    },
    {
      "type": "text",
      "id": "innov_code_text",
      "x": 545,
      "y": 320,
      "width": 370,
      "height": 300,
      "text": "\u2460 Regularized Objective\n  Obj = \u03a3 L(y\u1d62,\u0177\u1d62) + \u03b3\u00b7T + \u00bd\u03bb\u00b7\u03a3w\u2c7c\u00b2\n  \u2192 penalizes tree complexity\n\n\u2461 2nd-Order Taylor Expansion\n  Uses gradient g\u1d62 AND hessian h\u1d62\n  \u2192 better split decisions\n\n\u2462 Sparsity-Aware Splits\n  Missing values \u2192 learned default direction\n  \u2192 no imputation required\n\n\u2463 Column Subsampling\n  Random feature subsets per tree\n  \u2192 decorrelates trees, reduces variance\n\n\u2464 Shrinkage (learning rate \u03b7)\n  Each tree scaled by \u03b7 \u2208 [0.005, 0.3]\n  \u2192 more trees + small \u03b7 = better",
      "originalText": "\u2460 Regularized Objective\n  Obj = \u03a3 L(y\u1d62,\u0177\u1d62) + \u03b3\u00b7T + \u00bd\u03bb\u00b7\u03a3w\u2c7c\u00b2\n  \u2192 penalizes tree complexity\n\n\u2461 2nd-Order Taylor Expansion\n  Uses gradient g\u1d62 AND hessian h\u1d62\n  \u2192 better split decisions\n\n\u2462 Sparsity-Aware Splits\n  Missing values \u2192 learned default direction\n  \u2192 no imputation required\n\n\u2463 Column Subsampling\n  Random feature subsets per tree\n  \u2192 decorrelates trees, reduces variance\n\n\u2464 Shrinkage (learning rate \u03b7)\n  Each tree scaled by \u03b7 \u2208 [0.005, 0.3]\n  \u2192 more trees + small \u03b7 = better",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 20312,
      "version": 1,
      "versionNonce": 20313,
      "isDeleted": false,
      "groupIds": [],
