    {
      "type": "text",
      "id": "tct",
      "x": 675,
      "y": 140,
      "width": 250,
      "height": 145,
      "text": "\"Most tabular DL gains come\nfrom better training recipes,\nnot architectural novelty.\"\n\nGive an MLP the same treatment:\n  \u2713 NTK parameterization\n  \u2713 Robust preprocessing\n  \u2713 Pre-tuned defaults\n\u2192 matches complex architectures",
      "originalText": "\"Most tabular DL gains come\nfrom better training recipes,\nnot architectural novelty.\"\n\nGive an MLP the same treatment:\n  \u2713 NTK parameterization\n  \u2713 Robust preprocessing\n  \u2713 Pre-tuned defaults\n\u2192 matches complex architectures",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 90092,
      "version": 1,
      "versionNonce": 90093,
      "isDeleted": false,
      "groupIds": [],
