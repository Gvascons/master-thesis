      "link": null,
      "locked": false,
      "containerId": "thesis_code",
      "lineHeight": 1.25
    },
    {
      "type": "text",
      "id": "lr_note",
      "x": 660,
      "y": 280,
      "width": 280,
      "height": 65,
      "text": "LR: 0.02\u20130.3 (10-100\u00d7 higher than MLP!)\nEnabled by NTK parameterization\n\u2014 bounded output variance at any depth\n\u2014 stable training at high learning rates",
      "originalText": "LR: 0.02\u20130.3 (10-100\u00d7 higher than MLP!)\nEnabled by NTK parameterization\n\u2014 bounded output variance at any depth\n\u2014 stable training at high learning rates",
