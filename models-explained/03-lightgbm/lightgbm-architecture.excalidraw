    {
      "type": "text",
      "id": "hist_code_text",
      "x": 75,
      "y": 410,
      "width": 370,
      "height": 170,
      "text": "Raw:   [0.1, 0.3, 0.7, 0.2, 0.9, 0.5]\n              \u2193 bucket into 255 bins\nBinned: [bin\u2080, bin\u2081, bin\u2083, bin\u2081, bin\u2084, bin\u2082]\n\nSplit cost: O(255 \u00d7 features) vs O(n \u00d7 features)\n  \u2192 1 byte per feature per sample\n  \u2192 fits in CPU cache\n\nSubtraction trick:\n  hist(right) = hist(parent) - hist(left)",
      "originalText": "Raw:   [0.1, 0.3, 0.7, 0.2, 0.9, 0.5]\n              \u2193 bucket into 255 bins\nBinned: [bin\u2080, bin\u2081, bin\u2083, bin\u2081, bin\u2084, bin\u2082]\n\nSplit cost: O(255 \u00d7 features) vs O(n \u00d7 features)\n  \u2192 1 byte per feature per sample\n  \u2192 fits in CPU cache\n\nSubtraction trick:\n  hist(right) = hist(parent) - hist(left)",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 30222,
      "version": 1,
      "versionNonce": 30223,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "containerId": "hist_code",
      "lineHeight": 1.25
    },
