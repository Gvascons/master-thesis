    },
    {
      "type": "text",
      "id": "comp_text",
      "x": 530,
      "y": 358,
      "width": 400,
      "height": 110,
      "text": "FT-Transformer:\n  Feature \u2194 Feature only (column attention)\n\nSAINT adds:\n  Sample \u2194 Sample (row attention)\n  \u2192 richer context per prediction\n  \u2192 but batch-dependent, more expensive",
      "originalText": "FT-Transformer:\n  Feature \u2194 Feature only (column attention)\n\nSAINT adds:\n  Sample \u2194 Sample (row attention)\n  \u2192 richer context per prediction\n  \u2192 but batch-dependent, more expensive",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#64748b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
