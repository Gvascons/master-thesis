    {
      "type": "rectangle",
      "id": "rw_code",
      "x": 530,
      "y": 130,
      "width": 400,
      "height": 180,
      "strokeColor": "#1e293b",
      "backgroundColor": "#1e293b",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 70110,
      "version": 1,
      "versionNonce": 70111,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": [
        {
          "id": "rw_ct",
          "type": "text"
