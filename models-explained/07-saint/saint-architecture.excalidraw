    {
      "type": "text",
      "id": "rw_title",
      "x": 530,
      "y": 100,
      "width": 380,
      "height": 22,
      "text": "Row Attention: How It Works",
      "originalText": "Row Attention: How It Works",
      "fontSize": 16,
      "fontFamily": 3,
