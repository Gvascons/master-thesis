      ],
      "link": null,
      "locked": false,
      "roundness": {
        "type": 3
      }
    },
    {
      "type": "text",
      "id": "rw_ct",
      "x": 545,
      "y": 140,
      "width": 370,
      "height": 160,
      "text": "For each feature position j:\n  Q = sample_i's representation of feature j\n  K = ALL samples' representation of feature j\n  V = ALL samples' representation of feature j\n\nAttention across the batch dimension:\n  sample\u2081 \u2190 [0.6\u00b7sample\u2082 + 0.3\u00b7sample\u2083 + 0.1\u00b7sample\u2084]\n  \"Similar samples influence each other\"\n\nLike differentiable k-nearest-neighbors\nbut learned end-to-end within the network\n\n\u26a0 Batch composition affects predictions!",
      "originalText": "For each feature position j:\n  Q = sample_i's representation of feature j\n  K = ALL samples' representation of feature j\n  V = ALL samples' representation of feature j\n\nAttention across the batch dimension:\n  sample\u2081 \u2190 [0.6\u00b7sample\u2082 + 0.3\u00b7sample\u2083 + 0.1\u00b7sample\u2084]\n  \"Similar samples influence each other\"\n\nLike differentiable k-nearest-neighbors\nbut learned end-to-end within the network\n\n\u26a0 Batch composition affects predictions!",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 70112,
      "version": 1,
      "versionNonce": 70113,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "containerId": "rw_code",
      "lineHeight": 1.25
    },
    {
      "type": "text",
      "id": "comp_title",
      "x": 530,
      "y": 330,
      "width": 380,
      "height": 22,
      "text": "SAINT vs FT-Transformer",
      "originalText": "SAINT vs FT-Transformer",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#1e40af",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
